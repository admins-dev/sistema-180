# ═══════════════════════════════════════════════════════════════
# SISTEMA 180 — Railway Environment Variables Template
# Configura estas variables en Railway Dashboard → Variables
# NO subas este archivo con valores reales al repositorio
# ═══════════════════════════════════════════════════════════════

# Telegram Bot (OBLIGATORIO)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# AI APIs — NLP multi-provider cascade
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# TTS — Voice engine
# Motor: "edge" (gratis) o "elevenlabs" (premium)
TTS_ENGINE=edge
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Meta Ads (opcional)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Flask (auto-configurado por Railway)
PORT=5000
FLASK_ENV=production

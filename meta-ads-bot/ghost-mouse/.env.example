# ═══════════════════════════════════════════
# Ghost Mouse V2 — Environment Configuration
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Mode ──────────────────────────────────
# Options: DEV | DRY_RUN | PROD | SAFE_MODE
GM_MODE=DRY_RUN

# ── Database ──────────────────────────────
GM_DB_PATH=ghost_mouse.db

# ── LLM Keys (order: Groq free → Gemini Flash → Claude) ──
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (Brevo recommended over Gmail SMTP) ──
BREVO_API_KEY=
EMAIL_FROM=ghost@yourdomain.com
EMAIL_DOMAIN=yourdomain.com

# ── Scraping ──────────────────────────────
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=5.0
SCRAPE_MAX_CONCURRENCY=3
SCRAPE_BATCH_SIZE=50

# ── Feature Flags ─────────────────────────
FF_ENABLE_EMAIL_OUTREACH=false
FF_ENABLE_DM_OUTREACH=false
FF_ENABLE_WEB_ENRICHMENT=true
FF_ENABLE_LLM_SCORING=false

# ── Logging ───────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console

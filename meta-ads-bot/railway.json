{
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "startCommand": "python3 start_all.py",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "environmentVariables": {
      "PYTHON_VERSION": "3.12",
      "FLASK_ENV": "production"
    }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# SISTEMA 180 — Meta Ads Bot Configuration
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Meta Ads (Graph API v19.0) ───
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_123456789
META_PIXEL_ID=123456789

# ─── Telegram Bot API ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=12345,67890

# ─── Flask Configuration ───
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_PORT=5000
FLASK_API_SECRET=auto_generated_if_empty

# ─── Webhook Configuration ───
WEBHOOK_URL=https://your-railway-url.railway.app
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. META_ACCESS_TOKEN
#    - Go to https://developers.facebook.com/
#    - Create an app or use existing one
#    - Create a user access token with ads_read, ads_management permissions
#    - Valid for 60 days, then needs regeneration
#
# 2. META_AD_ACCOUNT_ID
#    - Format: act_XXXXXXXXX
#    - Found in: Meta Ads Manager → Settings → Ad Account ID
#    - This is the account where campaigns will be created
#
# 3. META_PIXEL_ID
#    - Your Meta pixel ID for conversion tracking
#    - Found in: Meta Events Manager → Pixels
#
# 4. TELEGRAM_BOT_TOKEN
#    - Go to https://t.me/BotFather
#    - Send /newbot and follow instructions
#    - Token format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
#
# 5. TELEGRAM_ALLOWED_USER_IDS
#    - Comma-separated list of user IDs allowed to use the bot
#    - Only these users can execute commands
#    - Get your ID by sending /start to @userinfobot
#    - Example: 123456,789012
#
# 6. FLASK_API_SECRET
#    - Used for X-API-Key header authentication
#    - If empty, auto-generated with secrets.token_hex(32)
#    - Should be a secure random string in production
#
# 7. WEBHOOK_URL
#    - Your Railway deployment URL: https://<project>.railway.app
#    - Used for Meta webhooks: https://<project>.railway.app/webhooks/graph-api
#
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# ⚠️  NEVER commit .env to git (already in .gitignore)
# ⚠️  NEVER share tokens in chat, email, or public channels
# ⚠️  ALWAYS use HTTPS in production (Railway provides SSL automatically)
# ⚠️  ALWAYS rotate tokens every 90 days
# ⚠️  ALWAYS limit API keys to minimum required permissions
#
# Token Rotation Schedule:
#   - META_ACCESS_TOKEN: Every 60 days (expires automatically)
#   - TELEGRAM_BOT_TOKEN: Every 90 days (rotate manually if compromised)
#   - FLASK_API_SECRET: Every 6 months or if exposed
#
# ═══════════════════════════════════════════════════════════════════════════════

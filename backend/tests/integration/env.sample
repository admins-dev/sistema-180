# tests/integration/env.sample
# Rellena antes de ejecutar o exporta en CI

# URL base del backend STAGING (sin slash final)
export STAGING_BASE_URL="http://localhost:3000"

# Authorization header para endpoints admin
export ADMIN_API_KEY="Bearer tu_admin_api_key_aqui"

# Stripe CLI API key (usa stripe login si no tienes key)
export STRIPE_CLI_KEY="sk_test_xxx"

# Price IDs en STRIPE TEST (Dashboard > Products > Prices)
export PRICE_ID_WEB="price_xxx"    # web_gancho 300€ one-time
export PRICE_ID_SUB="price_yyy"    # recepcionista_ia 100€/mes

# Email de cliente de prueba
export TEST_CUSTOMER_EMAIL="test+client@sistema180.com"

# Timeout curl (segundos)
export CURL_TIMEOUT=10
